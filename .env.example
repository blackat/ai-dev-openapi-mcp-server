# --- Target API ---
OPENAPI_SPEC=https://petstore3.swagger.io/api/v3/openapi.json
API_BASE_URL=
API_KEY=

# --- LLM backend: "ollama" or "gemini" ---
LLM_BACKEND=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- MCP server ---
MCP_HOST=127.0.0.1
MCP_PORT=8765
